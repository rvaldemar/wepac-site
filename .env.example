DATABASE_URL="postgresql://wepac:password@localhost:5432/wepac_production"
NEXTAUTH_SECRET="generate-a-random-32-char-secret"
NEXTAUTH_URL="https://wepac.pt"
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_FROM="info@wepac.pt"
APP_URL="https://wepac.pt"
# Persistent directory for bilheteira uploads (cover images). In prod point
# to a path outside the release dir so files survive deploys.
UPLOAD_DIR="./uploads"
# Base URL for auto-generated session video call rooms (see
# generateMeetingUrl in src/lib/wepacker/actions/session.ts). Defaults to
# the public Jitsi instance if unset; will migrate to a self-hosted
# instance later.
MEETING_BASE_URL="https://meet.jit.si"
# Selects the session-debrief AI engine: "anthropic" (default, calls the
# Anthropic API directly) or "hub" (routes through the Agents Hub playbook
# "wepac-session-debrief" / W01). See src/lib/wepacker/debrief/engine.ts.
DEBRIEF_ENGINE="anthropic"
# The 3 vars below are only required when DEBRIEF_ENGINE="hub" — the Hub
# client fails loud at construction if any is missing. Never real values
# here; ask the administrator for the WEPAC tenant's Agents Hub org API key.
# Base URL of the Agents Hub instance (no trailing slash), e.g. https://hub.example.com
HUB_API_URL="https://hub.example.com"
# Org-scoped Agents Hub API key (Authorization: Bearer <HUB_API_KEY>)
HUB_API_KEY="your_hub_api_key_here"
# UUID of the published "wepac-session-debrief" (W01) Playbook in the Hub
HUB_DEBRIEF_PLAYBOOK_ID="00000000-0000-0000-0000-000000000000"

# Cal.com self-service booking webhook (see rvs-cal repo + calcom-webhook
# route). Absent = the webhook endpoint 404s entirely (feature invisible).
# Set to the same secret configured on the Cal.com webhook subscription.
CALCOM_WEBHOOK_SECRET=

# Public booking page URL for the "Marcar sessão" block on the member
# sessions page (e.g. https://cal.rvs.solutions/<mentor-slug>). Absent =
# the block does not render.
CALCOM_BOOKING_URL=
