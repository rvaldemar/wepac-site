DATABASE_URL="postgresql://wepac:password@localhost:5432/wepac_local_dev"
# Destructive fixture seed requires both values and refuses non-loopback or
# prod/staging-named databases. Keep the confirmation equal to the URL DB name.
WEPACKER_SEED_ALLOW_DB_RESET="0"
WEPACKER_SEED_DATABASE_NAME="wepac_local_dev"
NEXTAUTH_SECRET="generate-a-random-32-char-secret"
AUTH_URL="https://wepac.pt"
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_FROM="info@wepac.pt"
APP_URL="https://wepac.pt"
# Persistent directory for bilheteira uploads (cover images). In prod point
# to a path outside the release dir so files survive deploys.
UPLOAD_DIR="./uploads"
# Base URL for auto-generated session video call rooms (see
# generateMeetingUrl in src/lib/wepacker/actions/session.ts). Defaults to
# the public Jitsi instance if unset; will migrate to a self-hosted
# instance later.
MEETING_BASE_URL="https://meet.jit.si"
# Session Debrief stays fail-closed until W01 v3 is published and certified by
# the Agents Hub team. Do not set this to "hub" before the certified release
# reference and service-principal credential have been returned.
DEBRIEF_ENGINE="disabled"
# Cutover-only variables (names reserved; values are supplied through the
# secret manager after certification, never committed here):
# HUB_API_URL=
# HUB_DEBRIEF_API_KEY=
# HUB_DEBRIEF_PLAYBOOK_ID=
# HUB_DEBRIEF_CONTRACT_VERSION="wepac-session-debrief-v3"
# Existing generic Wessex Hub adapter only; not a Session Debrief credential:
# HUB_API_KEY=
# Cal.com self-service booking webhook (see rvs-cal repo + calcom-webhook
# route). Absent = the webhook endpoint 404s entirely (feature invisible).
# Set to the same secret configured on the Cal.com webhook subscription.
CALCOM_WEBHOOK_SECRET=
# Keep false until a one-time booking grant or organizer confirmation proves
# who may create the canonical Session from a public Cal.com booking.
CALCOM_SESSION_INGEST_ENABLED=false

# Public booking page URL for the "Marcar sessão" block on the member
# sessions page (e.g. https://cal.rvs.solutions/<mentor-slug>). Absent =
# the block does not render.
CALCOM_BOOKING_URL=

# Stripe secret key for the bilheteira ticketing product (see
# src/lib/bilheteira/stripe.ts). Absent = isStripeConfigured() is false,
# so every paid checkout attempt fails with a user-facing error and no
# alert is raised — this fails silently in the background, not loudly.
STRIPE_SECRET_KEY=

# Signing secret for the Stripe webhook that fulfils checkouts and issues
# tickets (see src/app/api/bilheteira/stripe/webhook/route.ts). Absent =
# the webhook route returns 500 on every event, so paid tickets never get
# minted even if the Stripe Checkout payment itself succeeded.
STRIPE_WEBHOOK_SECRET=

# Keep false until verified age plus Parent/Guardian consent and evidence
# policy are implemented. False blocks new Mentorship invitations and
# acceptance, while decline and end/revocation always remain available.
MENTORSHIP_WRITES_ENABLED=false

# Durable transactional email retry worker for Pack, Connection, Mentorship,
# Session, Session follow-up and Message events. Immediate delivery is still
# attempted after commit; enable this on the long-lived Node runtime so
# pending/stale outbox rows recover automatically after process failure.
NOTIFICATION_OUTBOX_WORKER_ENABLED=false
NOTIFICATION_OUTBOX_WORKER_INTERVAL_MS=60000
NOTIFICATION_OUTBOX_WORKER_BATCH_SIZE=25

# Admin Support Preview grants expire after 15 minutes. This opt-in worker
# redacts expired ticket digests immediately, removes grants after 30 days and
# removes content-free audit events after 365 days. Enable only on the current
# single long-lived Node runtime; the interval is clamped to 1 hour-7 days.
SUPPORT_PREVIEW_RETENTION_WORKER_ENABLED=false
SUPPORT_PREVIEW_RETENTION_WORKER_INTERVAL_MS=86400000

# Keep false until Session-specific informed consent, age/Parent-Guardian
# evidence and a concrete retention policy are implemented. False blocks new
# Transcript attachments/replacements; erasure of existing Transcript and
# derived Debrief data always remains available.
SESSION_TRANSCRIPT_WRITES_ENABLED=false

# Private Session recording/transcription dark launch. Every flag is
# independent and fail-closed. Calls remain available when recording/STT is
# disabled or unavailable; start requires MEDIA + RECORDING + TRANSCRIPTION.
SESSION_MEDIA_ENABLED=false
SESSION_RECORDING_ENABLED=false
SESSION_TRANSCRIPTION_ENABLED=false
SESSION_RESULT_DOCUMENT_PUBLICATION_ENABLED=false
JITSI_JWT_ENABLED=false
SESSION_MEDIA_CONSENT_POLICY_VERSION="wepac-session-media-v1"
SESSION_RECORDING_RETENTION_DAYS=7
SESSION_TRANSCRIPT_RETENTION_DAYS=30
SESSION_RESULT_DOCUMENT_RETENTION_DAYS=365
# Parent containing the contract `recordings/<recording_id>/...` directory.
# Current Meet host layout; validate the mounted path during deployment.
SESSION_RECORDING_STORAGE_ROOT="/opt/rvs-meet/jitsi-cfg"
SESSION_RECORDING_MAX_MINUTES=90
SESSION_MEDIA_PRESENCE_MAX_AGE_SECONDS=45
SESSION_MEDIA_CALLBACK_MAX_SKEW_SECONDS=300
SESSION_MEDIA_RETENTION_WORKER_ENABLED=false
SESSION_MEDIA_RETENTION_WORKER_INTERVAL_MS=3600000
SESSION_TRANSCRIPTION_LANGUAGE="pt"
# Jitsi stable-11031 room verifier: iss=wepac, aud=jitsi and sub=meet.jitsi.
# `sub` is the internal virtual-host domain, not meet.rvs.solutions.
JITSI_JWT_SUB="meet.jitsi"
JITSI_JWT_ISSUER="wepac"
JITSI_JWT_AUDIENCE="jitsi"
# Secret values are provisioned directly in the production secret store:
# JITSI_JWT_SECRET=
# JIBRI_CALLBACK_SECRET=
# HUB_TRANSCRIPTION_CALLBACK_SECRET=
HUB_TRANSCRIPTION_API_URL="https://hub.rvs.solutions/api/v1"
HUB_TRANSCRIPTION_CONTRACT_VERSION="media-transcription.v1"
# HUB_TRANSCRIPTION_API_KEY=

# Selects the public Wessex chat AI engine: "direct" (default, calls the
# Anthropic API directly) or "hub" (routes through the Agents Hub's
# generic chat endpoint). See src/lib/wessex/chat-engine.ts. "hub" uses the
# generic HUB_API_URL/HUB_API_KEY pair — not HUB_DEBRIEF_API_KEY — and fails
# loud at construction if either is missing. Commented out because the
# code default ("direct") is safe to leave implicit.
# WESSEX_ENGINE="direct"
