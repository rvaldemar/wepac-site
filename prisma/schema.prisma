generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== WEPACKER PLATFORM — ENUMS =====

enum UserRole {
  member
  mentor
  admin
}

enum MemberLevel {
  seed
  growth
  signature
  partner
}

enum MemberPhase {
  diagnosis
  structuring
  development
  activation
  consolidation
}

enum CohortStatus {
  draft
  active
  completed
  archived
}

enum MembershipRole {
  member
  mentor
}

enum MembershipStatus {
  active
  paused
  exited
}

enum EvaluationType {
  self
  mentor
  professional
}

enum EvaluationMoment {
  entry
  mid
  exit
}

enum GoalScope {
  annual
  quarterly
}

enum GoalStatus {
  not_started
  in_progress
  completed
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskOrigin {
  plan
  session
  mentor
  self
}

enum SessionType {
  individual
  group
}

enum SessionStatus {
  scheduled
  completed
  cancelled
  no_show
}

enum AreaKey {
  physical
  emotional
  character
  spiritual
  intellectual
  social
}

// A Trail is a personal transformation journey a WEPACker defines for
// themselves — title, purpose, why it matters now, what real progress
// would look like, which development areas it touches. Standalone from
// Cohort/Journey in this first version: one person can run several
// Trails across their life, each optionally overlapping a Pack's
// Journey, but that link isn't modeled yet.
enum TrailStatus {
  active
  paused
  completed
  abandoned
}

// ===== WEPACKER PLATFORM — MODELS =====

// A Pack is the application of the WEPAC methodology to a specific
// profile/context (e.g. artist, sport). The 6 development areas are
// universal and fixed across every pack — art/culture (or any other
// discipline a pack is built around) is a practice a Pack chooses, not
// a pillar of its own.
model Pack {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String   @default("")
  description String   @default("")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cohorts Cohort[]

  @@map("packs")
}

// A Cohort is a closed accompaniment cycle within a Pack.
model Cohort {
  id        String       @id @default(cuid())
  packId    String
  name      String
  status    CohortStatus @default(draft)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  pack        Pack               @relation(fields: [packId], references: [id], onDelete: Cascade)
  memberships CohortMembership[]
  sessions    Session[]

  @@map("cohorts")
}

// A person inside a cohort — either a member in development or a mentor.
// Tasks and session attendance hang on the membership (they are specific
// to a pack cycle). The person-level development artefacts — evaluations,
// life plan, strategic plan/map — hang on the User instead (see below),
// so one person has a single PPV/diagnosis/plan even across several packs.
model CohortMembership {
  id           String           @id @default(cuid())
  cohortId     String
  userId       String
  role         MembershipRole   @default(member)
  status       MembershipStatus @default(active)
  level        MemberLevel      @default(seed)
  currentPhase MemberPhase      @default(diagnosis)
  joinedAt     DateTime         @default(now())

  cohort             Cohort            @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks              Task[]

  @@unique([cohortId, userId])
  @@index([userId])
  @@map("cohort_memberships")
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String?
  role            UserRole  @default(member)
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  onboarded       Boolean   @default(false)
  avatarUrl       String?
  bio             String?
  phone           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships         CohortMembership[]
  agreements          Agreement[]
  evaluations         Evaluation[]              @relation("EvaluationSubject")
  evaluationsGiven    Evaluation[]              @relation("EvaluationEvaluator")
  strategicMapScores  StrategicMapScore[]       @relation("StrategicMapSubject")
  strategicMapsGiven  StrategicMapScore[]       @relation("StrategicMapEvaluator")
  lifePlan            LifePlan?
  lifePlanVersions    LifePlanVersion[]
  strategicPlans      StrategicPlan[]
  trails              Trail[]
  tasksAssigned       Task[]                    @relation("TaskAssigner")
  sessionsMentored    Session[]
  sessionAttendances  SessionAttendee[]
  conversationLinks   ConversationParticipant[]
  messages            Message[]
  comments            Comment[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model Agreement {
  id         String   @id @default(cuid())
  userId     String
  version    String   @default("1.0")
  acceptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agreements")
}

// Belongs to the person (User), not a specific CohortMembership — one
// person has a single diagnosis history across every pack they join.
model Evaluation {
  id             String           @id @default(cuid())
  userId         String
  evaluatorId    String
  evaluationType EvaluationType
  moment         EvaluationMoment
  completedAt    DateTime?

  user      User              @relation("EvaluationSubject", fields: [userId], references: [id], onDelete: Cascade)
  evaluator User              @relation("EvaluationEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  scores    EvaluationScore[]

  @@index([userId])
  @@map("evaluations")
}

model EvaluationScore {
  id           String  @id @default(cuid())
  evaluationId String
  area         AreaKey
  indicator    String
  score        Int
  notes        String?

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@map("evaluation_scores")
}

// Belongs to the person (User), not a specific CohortMembership.
model StrategicMapScore {
  id             String  @id @default(cuid())
  userId         String
  evaluatorId    String
  month          String
  longTermScore  Int
  annualScore    Int
  quarterlyScore Int
  monthlyScore   Int
  notes          String?

  user      User @relation("StrategicMapSubject", fields: [userId], references: [id], onDelete: Cascade)
  evaluator User @relation("StrategicMapEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("strategic_map_scores")
}

// Belongs to the person (User) — a single mutable PPV per person, not
// per membership. `userId` is unique: one row per person.
model LifePlan {
  id          String   @id @default(cuid())
  userId      String   @unique
  whoIAm      String   @default("")
  whereIAm    String   @default("")
  whereIGo    String   @default("")
  whyIDo      String   @default("")
  commitments String   @default("")
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("life_plans")
}

// Append-only version history for LifePlan. A row is written with the
// PREVIOUS state right before a LifePlan is overwritten, so no update or
// delete should ever target this model — it exists purely to keep history.
model LifePlanVersion {
  id          String   @id @default(cuid())
  userId      String
  whoIAm      String   @default("")
  whereIAm    String   @default("")
  whereIGo    String   @default("")
  whyIDo      String   @default("")
  commitments String   @default("")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("life_plan_versions")
}

// Belongs to the person (User) — a personal transformation Trail. Not
// linked to Cohort/Journey in this version (see enum TrailStatus above).
model Trail {
  id           String      @id @default(cuid())
  userId       String
  title        String
  purpose      String      @default("")
  whyItMatters String      @default("")
  destination  String      @default("")
  areas        AreaKey[]
  status       TrailStatus @default(active)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trails")
}

// Belongs to the person (User), not a specific CohortMembership — one
// strategic plan history per person, spanning every pack they join.
model StrategicPlan {
  id                  String    @id @default(cuid())
  userId              String
  quarter             String
  longTermVision      String    @default("")
  positioning         String    @default("")
  focusAreas          AreaKey[]
  quarterlyReflection String    @default("")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals          Goal[]
  monthlyActions MonthlyAction[]

  @@index([userId])
  @@map("strategic_plans")
}

model Goal {
  id              String     @id @default(cuid())
  strategicPlanId String
  scope           GoalScope
  title           String
  description     String     @default("")
  successCriteria String     @default("")
  deadline        String
  status          GoalStatus @default(not_started)

  strategicPlan  StrategicPlan   @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
  monthlyActions MonthlyAction[]
  tasks          Task[]

  @@map("goals")
}

model MonthlyAction {
  id              String     @id @default(cuid())
  strategicPlanId String
  month           String
  title           String
  goalId          String?
  deadline        String
  status          TaskStatus @default(todo)

  strategicPlan StrategicPlan @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
  goal          Goal?         @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@map("monthly_actions")
}

model Task {
  id              String     @id @default(cuid())
  membershipId    String
  assignedById    String?
  title           String
  description     String?
  origin          TaskOrigin @default(self)
  goalId          String?
  deadline        String
  status          TaskStatus @default(todo)
  // Set when origin is "session": the mentoring session this task was
  // created from, for traceability back to the outcome that spawned it.
  sourceSessionId String?

  membership    CohortMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  assignedBy    User?            @relation("TaskAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  goal          Goal?            @relation(fields: [goalId], references: [id], onDelete: SetNull)
  sourceSession Session?         @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  comments      Comment[]        @relation("TaskComments")

  @@map("tasks")
}

// A Session is a mentoring session with a person (or a group of people).
// It can optionally sit inside a Pack/Journey (`cohortId`), but a Pack is
// just a community/context — most mentoring is a personal relationship,
// not a Journey-scoped category, so `cohortId` is optional. Attendees are
// people (`User`), not pack enrollments, so the same session model works
// whether or not it belongs to a cohort.
model Session {
  id               String        @id @default(cuid())
  cohortId         String?
  mentorId         String
  sessionType      SessionType
  scheduledAt      DateTime
  durationMinutes  Int           @default(60)
  status           SessionStatus @default(scheduled)
  // Deprecated for UI writes: a single mentor->everyone blob, wrong for
  // group sessions. Superseded by the per-attendee note fields below
  // (privateNote / sharedNote / sharedNotePublished / outcome). Kept for
  // backward compatibility with existing data; do not add new writers.
  notes            String?
  notesPublished   Boolean       @default(false)
  discussionPoints String?

  cohort       Cohort?           @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  mentor       User              @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  attendees    SessionAttendee[]
  sourcedTasks Task[]

  @@map("sessions")
}

model SessionAttendee {
  id        String  @id @default(cuid())
  sessionId String
  userId    String
  attended  Boolean @default(false)

  // Mentor-only, never shown to the member.
  privateNote         String?
  // Shown to the member, but only once sharedNotePublished is true.
  sharedNote          String?
  sharedNotePublished Boolean @default(false)
  // What was agreed/gained in the session, for this person specifically.
  outcome             String?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("session_attendees")
}

model Conversation {
  id           String                    @id @default(cuid())
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Comment {
  id              String   @id @default(cuid())
  userId          String
  taskId          String?
  commentableType String
  commentableId   String
  body            String
  createdAt       DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation("TaskComments", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([commentableType, commentableId])
  @@map("comments")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ===== LEAD MANAGEMENT =====

enum LeadStatus {
  new
  contacted
  converted
  lost
}

enum LeadSource {
  chat
  form
  contact
}

model Lead {
  id                  String     @id @default(cuid())
  name                String
  email               String?
  phone               String?
  eventType           String?
  eventDate           String?
  location            String?
  guestCount          Int?
  musicalPreferences  String?
  ensemble            String?
  estimatedBudget     String?
  notes               String?
  status              LeadStatus @default(new)
  conversationHistory Json?
  source              LeadSource @default(chat)
  consentGiven        Boolean    @default(false)
  consentTimestamp    DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@map("leads")
}

// ===== BETA SIGNUP =====

enum BetaSignupStatus {
  pending
  contacted
  invited
  joined
  rejected
}

model BetaSignup {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  phone        String?
  artisticArea String?
  socialLinks  String?
  motivation   String?
  status       BetaSignupStatus @default(pending)
  notes        String?
  // Pack the application targets; existing rows default to the artist pack.
  packSlug     String           @default("artist")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("beta_signups")
}

// ===== SEM NOME — BILHETE DIGITAL =====

model SemNomeTicket {
  id          String    @id @default(cuid())
  serial      Int       @unique @default(autoincrement())
  name        String
  seats       Int       @default(1)
  createdAt   DateTime  @default(now())
  checkedInAt DateTime?

  @@map("sem_nome_tickets")
}

// ===== BILHETEIRA WEPAC =====

enum EventStatus {
  draft
  published
  cancelled
  completed
}

enum TicketStatus {
  pending
  checked_in
  cancelled
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
  expired
}

model TicketingAdmin {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  passwordHash          String
  createdAt             DateTime  @default(now())
  lastLoginAt           DateTime?
  emailVerifiedAt       DateTime?
  verificationToken     String?   @unique
  verificationExpiresAt DateTime?

  events Event[]

  @@map("ticketing_admins")
}

model Department {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  brands      Brand[]
  events      Event[]

  @@map("departments")
}

model Brand {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  departmentId String
  createdAt    DateTime @default(now())

  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  events       Event[]

  @@map("brands")
}

model Event {
  id              String      @id @default(cuid())
  slug            String      @unique
  title           String
  subtitle        String?
  description     String
  departmentId    String
  brandId         String?
  venue           String
  address         String?
  startsAt        DateTime
  doorsAt         DateTime?
  durationMinutes Int?
  coverImage      String?
  capacity        Int?
  ticketNote      String?
  status          EventStatus @default(draft)
  createdById     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  department Department      @relation(fields: [departmentId], references: [id])
  brand      Brand?          @relation(fields: [brandId], references: [id])
  createdBy  TicketingAdmin? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  tiers      TicketTier[]
  tickets    Ticket[]
  payments   Payment[]

  @@index([status, startsAt])
  @@map("events")
}

model TicketTier {
  id            String   @id @default(cuid())
  eventId       String
  name          String
  description   String?
  priceCents    Int      @default(0)
  quantity      Int?
  sortOrder     Int      @default(0)
  stripePriceId String?
  createdAt     DateTime @default(now())

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets  Ticket[]
  payments Payment[]

  @@map("ticket_tiers")
}

model Ticket {
  id          String       @id @default(cuid())
  serial      Int          @unique @default(autoincrement())
  eventId     String
  tierId      String
  paymentId   String?      @unique
  buyerName         String
  buyerEmail        String
  buyerPhone        String?
  marketingConsent  Boolean      @default(false)
  seats             Int          @default(1)
  priceCents        Int          @default(0)
  status            TicketStatus @default(pending)
  notes             String?
  checkedInAt       DateTime?
  createdAt         DateTime     @default(now())

  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tier      TicketTier       @relation(fields: [tierId], references: [id])
  payment   Payment?         @relation(fields: [paymentId], references: [id])
  checkLogs TicketCheckLog[]

  @@index([eventId, status])
  @@map("tickets")
}

model TicketCheckLog {
  id        String   @id @default(cuid())
  ticketId  String
  action    String   // "checkin" | "checkout"
  adminId   String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_check_logs")
}

model Payment {
  id          String        @id @default(cuid())
  provider    String        @default("stripe")
  providerRef String        @unique
  amountCents Int
  currency    String        @default("eur")
  status      PaymentStatus @default(pending)
  eventId     String
  tierId      String
  seats       Int           @default(1)
  buyerName         String
  buyerEmail        String
  buyerPhone        String?
  marketingConsent  Boolean       @default(false)
  metadata          Json?
  paidAt      DateTime?
  failedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event  Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tier   TicketTier @relation(fields: [tierId], references: [id])
  ticket Ticket?

  @@index([eventId, status])
  @@map("payments")
}
