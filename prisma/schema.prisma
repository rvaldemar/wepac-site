generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== WEPACKER PLATFORM — ENUMS =====

enum UserRole {
  member
  mentor
  admin
}

enum MemberLevel {
  seed
  growth
  signature
  partner
}

enum MemberPhase {
  diagnosis
  structuring
  development
  activation
  consolidation
}

enum CohortStatus {
  draft
  active
  completed
  archived
}

enum MembershipRole {
  member
  mentor
}

enum MembershipStatus {
  active
  paused
  exited
}

// Origin metadata for Domain Graph v2 records. `legacy_inference` is
// intentionally explicit: inferred records must also set reviewRequired=true
// and are never created by this migration. Database checks quarantine every
// reviewRequired record from an active status until a human clears the flag.
enum DomainRecordSource {
  explicit
  invitation
  admin
  system
  legacy_inference
}

enum PersonConnectionType {
  friend
  family
  partner
  professional
  collaborator
  other
}

enum PersonConnectionStatus {
  pending
  active
  declined
  ended
  blocked
}

enum MentorshipStatus {
  pending
  active
  paused
  declined
  ended
}

enum PackMembershipRole {
  owner
  moderator
  member
}

enum PackMembershipStatus {
  invited
  active
  paused
  left
  removed
}

enum CommunityPackStatus {
  draft
  active
  archived
}

enum CycleEnrollmentStatus {
  invited
  active
  paused
  completed
  withdrawn
  removed
}

enum CycleFacilitatorRole {
  lead
  facilitator
}

enum CycleFacilitatorStatus {
  invited
  active
  paused
  declined
  ended
  removed
}

enum StageKey {
  easy_peasy
  step_up
  yup
}

enum StagePlacementStatus {
  pending_review
  active
  completed
  superseded
  voided
}

enum EvaluationType {
  self
  mentor
  professional
}

enum EvaluationMoment {
  entry
  mid
  exit
}

enum GoalScope {
  annual
  quarterly
}

enum GoalStatus {
  not_started
  in_progress
  completed
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum TaskOrigin {
  plan
  session
  mentor
  self
}

enum SessionType {
  individual
  group
}

enum SessionStatus {
  scheduled
  completed
  cancelled
  no_show
}

// The purpose of a session, from the WEPACKER mountain imaginary —
// orthogonal to SessionType (which is FORMAT: individual/group).
enum SessionKind {
  checkpoint
  recon
  basecamp
  rescue
  summit
}

enum AreaKey {
  physical
  emotional
  character
  spiritual
  intellectual
  social
}

// A Trail is a bounded personal transformation a WEPACker defines and owns.
// It belongs to My Journey and remains independent from legacy delivery rows.
enum TrailStatus {
  active
  paused
  completed
  abandoned
}

// Minimal status for a SessionDebrief row — drives the review UI's Error
// state only. There is no "generating"/pending lock state: generation is
// synchronous (a single mentor does not race themselves), so a row is
// only ever created once the AI call has already settled, either ready
// or failed.
enum DebriefStatus {
  ready
  failed
}

// ===== WEPACKER PLATFORM — MODELS =====

// LEGACY DELIVERY MODEL. These rows historically mixed audience, practice
// and product concepts. They are not target Community Packs or verified
// Disciplines; see CommunityPack and the Domain Graph v2 ADR.
model Pack {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String   @default("")
  description String   @default("")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cohorts Cohort[]

  @@map("packs")
}

// LEGACY DELIVERY MODEL. A Cohort is not a target Cycle until reviewed and
// explicitly mapped.
model Cohort {
  id        String       @id @default(cuid())
  packId    String
  name      String
  status    CohortStatus @default(draft)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  pack              Pack               @relation(fields: [packId], references: [id], onDelete: Cascade)
  memberships       CohortMembership[]
  cycleEnrollments  CycleEnrollment[]
  cycleFacilitators CycleFacilitator[]
  sessions          Session[]

  @@map("cohorts")
}

// LEGACY DELIVERY MODEL. This row is not target Cycle Enrollment, Cycle
// Facilitator, Pack Membership, Connection or Mentorship. Tasks remain here
// only as contained legacy data during migration.
model CohortMembership {
  id           String           @id @default(cuid())
  cohortId     String
  userId       String
  role         MembershipRole   @default(member)
  status       MembershipStatus @default(active)
  level        MemberLevel      @default(seed)
  currentPhase MemberPhase      @default(diagnosis)
  joinedAt     DateTime         @default(now())

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]

  @@unique([cohortId, userId])
  @@index([userId])
  @@map("cohort_memberships")
}

model User {
  id              String    @id @default(cuid())
  name            String
  email           String    @unique
  passwordHash    String?
  role            UserRole  @default(member)
  inviteToken     String?   @unique
  inviteExpiresAt DateTime?
  onboarded       Boolean   @default(false)
  avatarUrl       String?
  bio             String?
  phone           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  memberships                CohortMembership[]
  agreements                 Agreement[]
  evaluations                Evaluation[]              @relation("EvaluationSubject")
  evaluationsGiven           Evaluation[]              @relation("EvaluationEvaluator")
  strategicMapScores         StrategicMapScore[]       @relation("StrategicMapSubject")
  strategicMapsGiven         StrategicMapScore[]       @relation("StrategicMapEvaluator")
  lifePlan                   LifePlan?
  lifePlanVersions           LifePlanVersion[]
  strategicPlans             StrategicPlan[]
  trails                     Trail[]
  tasksAssigned              Task[]                    @relation("TaskAssigner")
  sessionsMentored           Session[]
  sessionAttendances         SessionAttendee[]
  sessionTranscriptsUploaded Session[]                 @relation("SessionTranscriptUploader")
  sessionDebriefsGenerated   SessionDebrief[]
  conversationLinks          ConversationParticipant[]
  messages                   Message[]
  comments                   Comment[]
  passwordResetTokens        PasswordResetToken[]
  connectionsAsFirst         PersonConnection[]        @relation("PersonConnectionFirstUser")
  connectionsAsSecond        PersonConnection[]        @relation("PersonConnectionSecondUser")
  connectionsRequested       PersonConnection[]        @relation("PersonConnectionRequestedBy")
  mentorshipsAsMentor        Mentorship[]              @relation("MentorshipMentor")
  mentorshipsAsMentee        Mentorship[]              @relation("MentorshipMentee")
  mentorshipInvitationsSent  Mentorship[]              @relation("MentorshipInvitedBy")
  communityPacksCreated      CommunityPack[]           @relation("CommunityPackCreator")
  packMemberships            PackMembership[]
  packInvitationsSent        PackMembership[]          @relation("PackMembershipInvitedBy")
  cycleEnrollments           CycleEnrollment[]
  cycleFacilitations         CycleFacilitator[]
  stagePlacements            StagePlacement[]          @relation("StagePlacementSubject")
  stagePlacementsMade        StagePlacement[]          @relation("StagePlacementPlacedBy")

  @@map("users")
}

// A consented person-to-person connection. The two user IDs form an
// unordered pair: the database check keeps them in canonical lexical order,
// allowing one durable connection record per pair. The optional per-person
// labels support asymmetric real-world relationships without overloading
// Mentorship, which has its own directed model below. Consent/history endpoints
// use Restrict; future erasure must be an explicit, policy-reviewed
// anonymization workflow rather than an accidental cascade.
model PersonConnection {
  id                 String                 @id @default(cuid())
  firstUserId        String
  secondUserId       String
  requestedById      String?
  type               PersonConnectionType
  status             PersonConnectionStatus @default(pending)
  labelForFirstUser  String?
  labelForSecondUser String?
  source             DomainRecordSource     @default(explicit)
  reviewRequired     Boolean                @default(false)
  requestedAt        DateTime               @default(now())
  acceptedAt         DateTime?
  endedAt            DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  firstUser   User  @relation("PersonConnectionFirstUser", fields: [firstUserId], references: [id], onDelete: Restrict)
  secondUser  User  @relation("PersonConnectionSecondUser", fields: [secondUserId], references: [id], onDelete: Restrict)
  requestedBy User? @relation("PersonConnectionRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)

  @@unique([firstUserId, secondUserId])
  @@index([firstUserId, status])
  @@index([secondUserId, status])
  @@index([requestedById])
  @@map("person_connections")
}

// A directed, consented mentor -> mentee relationship. It is independent
// from Packs and Cycles: a personal mentoring relationship exists without
// requiring either kind of membership.
model Mentorship {
  id               String             @id @default(cuid())
  mentorId         String
  menteeId         String
  invitedById      String
  status           MentorshipStatus   @default(pending)
  source           DomainRecordSource @default(explicit)
  reviewRequired   Boolean            @default(false)
  invitedAt        DateTime           @default(now())
  mentorAcceptedAt DateTime?
  menteeAcceptedAt DateTime?
  activatedAt      DateTime?
  pausedAt         DateTime?
  endedAt          DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  mentor    User      @relation("MentorshipMentor", fields: [mentorId], references: [id], onDelete: Restrict)
  mentee    User      @relation("MentorshipMentee", fields: [menteeId], references: [id], onDelete: Restrict)
  invitedBy User      @relation("MentorshipInvitedBy", fields: [invitedById], references: [id], onDelete: Restrict)
  sessions  Session[]

  @@index([mentorId, menteeId])
  @@index([mentorId, status])
  @@index([menteeId, status])
  @@index([invitedById])
  @@map("mentorships")
}

// Target community aggregate. It is intentionally separate from legacy Pack,
// whose current rows describe profile/practice concepts such as Artist. No
// legacy Pack row is reused or inferred as a CommunityPack by this migration.
model CommunityPack {
  id             String              @id @default(cuid())
  slug           String              @unique
  name           String
  description    String              @default("")
  status         CommunityPackStatus @default(draft)
  source         DomainRecordSource  @default(explicit)
  reviewRequired Boolean             @default(false)
  createdById    String
  activatedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  createdBy   User             @relation("CommunityPackCreator", fields: [createdById], references: [id], onDelete: Restrict)
  memberships PackMembership[]

  @@index([status])
  @@index([createdById])
  @@map("community_packs")
}

// Community belonging only. This deliberately has no relationship to legacy
// Pack or CohortMembership: delivery participation must never silently become
// community belonging.
model PackMembership {
  id              String               @id @default(cuid())
  communityPackId String
  userId          String
  invitedById     String
  role            PackMembershipRole   @default(member)
  status          PackMembershipStatus @default(invited)
  source          DomainRecordSource   @default(explicit)
  reviewRequired  Boolean              @default(false)
  invitedAt       DateTime             @default(now())
  joinedAt        DateTime?
  endedAt         DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  communityPack CommunityPack @relation(fields: [communityPackId], references: [id], onDelete: Restrict)
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  invitedBy     User          @relation("PackMembershipInvitedBy", fields: [invitedById], references: [id], onDelete: Restrict)

  @@unique([communityPackId, userId])
  @@index([communityPackId, status])
  @@index([userId, status])
  @@index([invitedById])
  @@map("pack_memberships")
}

// Participant consent edge for a product-facing Cycle, temporarily backed by
// the legacy Cohort container. It is intentionally distinct from facilitation.
model CycleEnrollment {
  id             String                @id @default(cuid())
  cohortId       String
  userId         String
  status         CycleEnrollmentStatus @default(invited)
  source         DomainRecordSource    @default(explicit)
  reviewRequired Boolean               @default(false)
  invitedAt      DateTime              @default(now())
  joinedAt       DateTime?
  completedAt    DateTime?
  endedAt        DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([cohortId, userId])
  @@index([cohortId, status])
  @@index([userId, status])
  @@map("cycle_enrollments")
}

// Operational facilitation edge for a Cycle. A Person may simultaneously have
// a CycleEnrollment; separate tables prevent one role from overwriting the
// other and keep authorization scopes independent.
model CycleFacilitator {
  id             String                 @id @default(cuid())
  cohortId       String
  userId         String
  role           CycleFacilitatorRole   @default(facilitator)
  status         CycleFacilitatorStatus @default(invited)
  source         DomainRecordSource     @default(explicit)
  reviewRequired Boolean                @default(false)
  invitedAt      DateTime               @default(now())
  acceptedAt     DateTime?
  endedAt        DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  cohort Cohort @relation(fields: [cohortId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([cohortId, userId])
  @@index([cohortId, status])
  @@index([userId, status])
  @@map("cycle_facilitators")
}

// Historical placement in one of the three lifelong Stages. A partial unique
// index in the migration enforces at most one active placement per person.
model StagePlacement {
  id             String               @id @default(cuid())
  userId         String
  stage          StageKey
  status         StagePlacementStatus @default(active)
  source         DomainRecordSource   @default(explicit)
  reviewRequired Boolean              @default(false)
  placedById     String?
  effectiveFrom  DateTime             @default(now())
  effectiveUntil DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  user     User  @relation("StagePlacementSubject", fields: [userId], references: [id], onDelete: Restrict)
  placedBy User? @relation("StagePlacementPlacedBy", fields: [placedById], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([placedById])
  @@map("stage_placements")
}

model Agreement {
  id         String   @id @default(cuid())
  userId     String
  version    String   @default("1.0")
  acceptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("agreements")
}

// Belongs to the person (User), not a specific CohortMembership — one
// person has a single diagnosis history across every pack they join.
model Evaluation {
  id             String           @id @default(cuid())
  userId         String
  evaluatorId    String
  evaluationType EvaluationType
  moment         EvaluationMoment
  completedAt    DateTime?

  user      User              @relation("EvaluationSubject", fields: [userId], references: [id], onDelete: Cascade)
  evaluator User              @relation("EvaluationEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)
  scores    EvaluationScore[]

  @@index([userId])
  @@map("evaluations")
}

model EvaluationScore {
  id           String  @id @default(cuid())
  evaluationId String
  area         AreaKey
  indicator    String
  score        Int
  notes        String?

  evaluation Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@map("evaluation_scores")
}

// Belongs to the person (User), not a specific CohortMembership.
model StrategicMapScore {
  id             String  @id @default(cuid())
  userId         String
  evaluatorId    String
  month          String
  longTermScore  Int
  annualScore    Int
  quarterlyScore Int
  monthlyScore   Int
  notes          String?

  user      User @relation("StrategicMapSubject", fields: [userId], references: [id], onDelete: Cascade)
  evaluator User @relation("StrategicMapEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("strategic_map_scores")
}

// Belongs to the person (User) — a single mutable PPV per person, not
// per membership. `userId` is unique: one row per person.
model LifePlan {
  id          String   @id @default(cuid())
  userId      String   @unique
  whoIAm      String   @default("")
  whereIAm    String   @default("")
  whereIGo    String   @default("")
  whyIDo      String   @default("")
  commitments String   @default("")
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("life_plans")
}

// Append-only version history for LifePlan. A row is written with the
// PREVIOUS state right before a LifePlan is overwritten, so no update or
// delete should ever target this model — it exists purely to keep history.
model LifePlanVersion {
  id          String   @id @default(cuid())
  userId      String
  whoIAm      String   @default("")
  whereIAm    String   @default("")
  whereIGo    String   @default("")
  whyIDo      String   @default("")
  commitments String   @default("")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("life_plan_versions")
}

// Belongs to the person (User) — a personal transformation Trail. Not
// linked to Cohort/Journey in this version (see enum TrailStatus above).
model Trail {
  id           String      @id @default(cuid())
  userId       String
  title        String
  purpose      String      @default("")
  whyItMatters String      @default("")
  destination  String      @default("")
  areas        AreaKey[]
  status       TrailStatus @default(active)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trails")
}

// Belongs to the person (User), not a specific CohortMembership — one
// strategic plan history per person, spanning every pack they join.
model StrategicPlan {
  id                  String    @id @default(cuid())
  userId              String
  quarter             String
  longTermVision      String    @default("")
  positioning         String    @default("")
  focusAreas          AreaKey[]
  quarterlyReflection String    @default("")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals          Goal[]
  monthlyActions MonthlyAction[]

  @@index([userId])
  @@map("strategic_plans")
}

model Goal {
  id              String     @id @default(cuid())
  strategicPlanId String
  scope           GoalScope
  title           String
  description     String     @default("")
  successCriteria String     @default("")
  deadline        String
  status          GoalStatus @default(not_started)

  strategicPlan  StrategicPlan   @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
  monthlyActions MonthlyAction[]
  tasks          Task[]

  @@map("goals")
}

model MonthlyAction {
  id              String     @id @default(cuid())
  strategicPlanId String
  month           String
  title           String
  goalId          String?
  deadline        String
  status          TaskStatus @default(todo)

  strategicPlan StrategicPlan @relation(fields: [strategicPlanId], references: [id], onDelete: Cascade)
  goal          Goal?         @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@map("monthly_actions")
}

model Task {
  id              String     @id @default(cuid())
  membershipId    String
  assignedById    String?
  title           String
  description     String?
  origin          TaskOrigin @default(self)
  goalId          String?
  deadline        String
  status          TaskStatus @default(todo)
  // Set when origin is "session": the mentoring session this task was
  // created from, for traceability back to the outcome that spawned it.
  sourceSessionId String?

  membership    CohortMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  assignedBy    User?            @relation("TaskAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  goal          Goal?            @relation(fields: [goalId], references: [id], onDelete: SetNull)
  sourceSession Session?         @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  comments      Comment[]        @relation("TaskComments")

  @@map("tasks")
}

// A Session has explicit attendees. It can optionally reference legacy
// delivery context (`cohortId`), but that is not a target Cycle mapping.
// Attendees are people (`User`), never inferred from a container.
model Session {
  id               String        @id @default(cuid())
  cohortId         String?
  mentorshipId     String?
  mentorId         String
  sessionType      SessionType
  kind             SessionKind   @default(checkpoint)
  scheduledAt      DateTime
  durationMinutes  Int           @default(60)
  status           SessionStatus @default(scheduled)
  // Video call link — auto-generated on creation (see generateMeetingUrl in
  // src/lib/wepacker/actions/session.ts) or replaced by the mentor with a
  // manual Zoom/Teams/etc link via updateSession. Member-safe: no privacy
  // concerns like privateNote, so it's fine on every member-facing read
  // path (ownAttendeeSessionSelect, dashboard's next session).
  meetingUrl       String?
  // Cal.com booking UID (payload.uid on every webhook delivery for a
  // booking) — nullable because manually-created sessions never go
  // through Cal.com. This is the idempotency anchor for the webhook
  // receiver (src/app/api/wepacker/calcom-webhook/route.ts): Cal.com is
  // at-least-once delivery, so the @unique constraint (not a
  // check-then-create race) is what actually prevents a duplicate
  // Session on a retried BOOKING_CREATED.
  calcomBookingUid String?       @unique
  // Deprecated for UI writes: a single mentor->everyone blob, wrong for
  // group sessions. Superseded by the per-attendee note fields below
  // (privateNote / sharedNote / sharedNotePublished / outcome). Kept for
  // backward compatibility with existing data; do not add new writers.
  notes            String?
  notesPublished   Boolean       @default(false)
  discussionPoints String?

  // Raw meeting transcript (markdown/plain text) — pasted, or read
  // client-side from an uploaded .txt/.md file and sent as text. Source
  // input for the AI debrief engine. Mentor-only: must never be added to
  // ownAttendeeSessionInclude, the member-facing select, or any other
  // member-facing read path (see src/lib/wepacker/actions/session.ts).
  transcript             String?
  // Monotonic source version for debrief generation. Content hashes alone
  // cannot distinguish a same-content replacement or an A -> B -> A cycle.
  transcriptRevision     Int       @default(0)
  transcriptUploadedAt   DateTime?
  transcriptUploadedById String?

  cohort               Cohort?           @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  mentorship           Mentorship?       @relation(fields: [mentorshipId], references: [id], onDelete: SetNull)
  mentor               User              @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  transcriptUploadedBy User?             @relation("SessionTranscriptUploader", fields: [transcriptUploadedById], references: [id], onDelete: SetNull)
  attendees            SessionAttendee[]
  sourcedTasks         Task[]
  debrief              SessionDebrief?

  @@index([mentorshipId])
  @@map("sessions")
}

// One AI-generated debrief draft per session (upsert on sessionId —
// regenerating overwrites this row rather than keeping history, matching
// the review UI's "descartar e gerar novo" flow). Nothing here is ever
// member-visible: approving a suggestion writes straight to the real
// table (SessionAttendee via updateSessionAttendee, Task via
// createTaskFromSession) — this row is scratch space for the mentor's
// review, not a published artefact.
model SessionDebrief {
  id                     String        @id @default(cuid())
  sessionId              String        @unique
  status                 DebriefStatus
  engineImpl             String? // "anthropic-direct" | "hub"
  model                  String?
  // DebriefResult.perAttendee (src/lib/wepacker/debrief/types.ts)
  perAttendeeSuggestions Json?
  // DebriefResult.internalEvaluation
  internalEvaluation     Json?
  // DebriefResult.resultDocumentHtml — null for group sessions (v1 only
  // generates a personal result document for individual sessions).
  resultDocumentHtml     String?
  // User-safe error message when status = failed (never the raw SDK
  // error, never transcript/prompt content).
  error                  String?
  requestedById          String
  requestedAt            DateTime      @default(now())
  generatedAt            DateTime?

  session     Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  requestedBy User    @relation(fields: [requestedById], references: [id], onDelete: Cascade)

  @@map("session_debriefs")
}

model SessionAttendee {
  id        String  @id @default(cuid())
  sessionId String
  userId    String
  attended  Boolean @default(false)

  // Mentor-only, never shown to the member.
  privateNote         String?
  // Shown to the member, but only once sharedNotePublished is true.
  sharedNote          String?
  sharedNotePublished Boolean @default(false)
  // What was agreed/gained in the session, for this person specifically.
  outcome             String?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("session_attendees")
}

model Conversation {
  id           String                    @id @default(cuid())
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  body           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Comment {
  id              String   @id @default(cuid())
  userId          String
  taskId          String?
  commentableType String
  commentableId   String
  body            String
  createdAt       DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation("TaskComments", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([commentableType, commentableId])
  @@map("comments")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ===== LEAD MANAGEMENT =====

enum LeadStatus {
  new
  contacted
  converted
  lost
}

enum LeadSource {
  chat
  form
  contact
}

model Lead {
  id                  String     @id @default(cuid())
  name                String
  email               String?
  phone               String?
  eventType           String?
  eventDate           String?
  location            String?
  guestCount          Int?
  musicalPreferences  String?
  ensemble            String?
  estimatedBudget     String?
  notes               String?
  status              LeadStatus @default(new)
  conversationHistory Json?
  source              LeadSource @default(chat)
  consentGiven        Boolean    @default(false)
  consentTimestamp    DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@map("leads")
}

// ===== BETA SIGNUP =====

enum BetaSignupStatus {
  pending
  contacted
  invited
  joined
  rejected
}

model BetaSignup {
  id           String           @id @default(cuid())
  name         String
  email        String           @unique
  phone        String?
  artisticArea String?
  socialLinks  String?
  motivation   String?
  status       BetaSignupStatus @default(pending)
  notes        String?
  // Pack the application targets; existing rows default to the artist pack.
  packSlug     String           @default("artist")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("beta_signups")
}

// ===== SEM NOME — BILHETE DIGITAL =====

model SemNomeTicket {
  id          String    @id @default(cuid())
  serial      Int       @unique @default(autoincrement())
  name        String
  seats       Int       @default(1)
  createdAt   DateTime  @default(now())
  checkedInAt DateTime?

  @@map("sem_nome_tickets")
}

// ===== BILHETEIRA WEPAC =====

enum EventStatus {
  draft
  published
  cancelled
  completed
}

enum TicketStatus {
  pending
  checked_in
  cancelled
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
  expired
}

model TicketingAdmin {
  id                    String    @id @default(cuid())
  email                 String    @unique
  name                  String
  passwordHash          String
  createdAt             DateTime  @default(now())
  lastLoginAt           DateTime?
  emailVerifiedAt       DateTime?
  verificationToken     String?   @unique
  verificationExpiresAt DateTime?

  events Event[]

  @@map("ticketing_admins")
}

model Department {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  brands Brand[]
  events Event[]

  @@map("departments")
}

model Brand {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  departmentId String
  createdAt    DateTime @default(now())

  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  events     Event[]

  @@map("brands")
}

model Event {
  id              String      @id @default(cuid())
  slug            String      @unique
  title           String
  subtitle        String?
  description     String
  departmentId    String
  brandId         String?
  venue           String
  address         String?
  startsAt        DateTime
  doorsAt         DateTime?
  durationMinutes Int?
  coverImage      String?
  capacity        Int?
  ticketNote      String?
  status          EventStatus @default(draft)
  createdById     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  department Department      @relation(fields: [departmentId], references: [id])
  brand      Brand?          @relation(fields: [brandId], references: [id])
  createdBy  TicketingAdmin? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  tiers      TicketTier[]
  tickets    Ticket[]
  payments   Payment[]

  @@index([status, startsAt])
  @@map("events")
}

model TicketTier {
  id            String   @id @default(cuid())
  eventId       String
  name          String
  description   String?
  priceCents    Int      @default(0)
  quantity      Int?
  sortOrder     Int      @default(0)
  stripePriceId String?
  createdAt     DateTime @default(now())

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets  Ticket[]
  payments Payment[]

  @@map("ticket_tiers")
}

model Ticket {
  id               String       @id @default(cuid())
  serial           Int          @unique @default(autoincrement())
  eventId          String
  tierId           String
  paymentId        String?      @unique
  buyerName        String
  buyerEmail       String
  buyerPhone       String?
  marketingConsent Boolean      @default(false)
  seats            Int          @default(1)
  priceCents       Int          @default(0)
  status           TicketStatus @default(pending)
  notes            String?
  checkedInAt      DateTime?
  createdAt        DateTime     @default(now())

  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tier      TicketTier       @relation(fields: [tierId], references: [id])
  payment   Payment?         @relation(fields: [paymentId], references: [id])
  checkLogs TicketCheckLog[]

  @@index([eventId, status])
  @@map("tickets")
}

model TicketCheckLog {
  id        String   @id @default(cuid())
  ticketId  String
  action    String // "checkin" | "checkout"
  adminId   String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_check_logs")
}

model Payment {
  id               String        @id @default(cuid())
  provider         String        @default("stripe")
  providerRef      String        @unique
  amountCents      Int
  currency         String        @default("eur")
  status           PaymentStatus @default(pending)
  eventId          String
  tierId           String
  seats            Int           @default(1)
  buyerName        String
  buyerEmail       String
  buyerPhone       String?
  marketingConsent Boolean       @default(false)
  metadata         Json?
  paidAt           DateTime?
  failedAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  event  Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tier   TicketTier @relation(fields: [tierId], references: [id])
  ticket Ticket?

  @@index([eventId, status])
  @@map("payments")
}
